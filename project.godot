; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="GAME_TEMPLATE"
run/main_scene="res://__GAME/game.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://common/textures/images/template_icon.png"

[audio]

buses/default_bus_layout="res://common/audio/default_bus_layout.tres"

[autoload]

Events="*res://_AUTOLOADS/events.gd"
ConfigManager="*res://_AUTOLOADS/config_manager.gd"

[display]

window/stretch/mode="canvas_items"

[editor]

run/main_run_args="Single"

[editor_plugins]

enabled=PackedStringArray("res://addons/favorite_scenes/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[file_customization]

folder_colors={
"res://_3D/": "blue",
"res://_3D/character/": "red",
"res://_3D/character/state_machine/": "green",
"res://_3D/world/": "red",
"res://_3D/world/levels/": "green",
"res://_AUTOLOADS/": "yellow",
"res://_ENTITIES/": "red",
"res://_GUI/": "blue",
"res://_GUI/hud/": "red",
"res://_GUI/menu/": "red",
"res://_GUI/menu/main_menu/": "green",
"res://_GUI/menu/settings/": "green",
"res://_GUI/menu/settings/components/": "yellow",
"res://_LOGIC/": "purple",
"res://_NETWORK/": "blue",
"res://_NETWORK/network_agent/": "red",
"res://_NETWORK/network_agent/client/": "green",
"res://_NETWORK/network_agent/server/": "green",
"res://_NETWORK/roster/": "red",
"res://_NETWORK/roster/player/": "green",
"res://_SYSTEMS/": "green",
"res://abstract_classes/": "pink",
"res://addons/": "gray",
"res://common/": "gray",
"res://common/textures/materials/": "gray",
"res://custom/": "gray",
"res://imports/": "gray"
}

